<mujocoinclude>

    <body name="kettleroot" childclass="kettle">
        <!-- 壶身 mesh（你已在 kettle_asset.xml 里对 mesh 做 scale=0.5，这里保持不动） -->
        <geom mesh="kettle"/>

        <!-- ========== 视觉/把手结构（capsule/sphere）全部按 0.5 缩放 ========== -->
        <geom material="kettle_wood" euler="0 1.57 0" pos="0 0 0.1295" size="0.016 0.05" type="capsule"/>
        <geom material="kettle_wood" euler="0 1.57 0" pos="0 0 0.065"  size="0.0055" type="sphere"/>
        <geom euler="0 1.57 0"                 pos="0 0 0.1295" size="0.01 0.0575" type="capsule"/>
        <geom pos="0.046 0 0.093"              size="0.01 0.035" type="capsule"/>
        <geom pos="-0.046 0 0.0925"            size="0.01 0.035" type="capsule"/>
        <geom material="kettle_wood" pos="-0.046 0 0.11" size="0.011 0.0075" type="capsule"/>
        <geom material="kettle_wood" pos="0.046 0 0.11"  size="0.011 0.0075" type="capsule"/>

        <!-- ========== 碰撞几何（kettle_collision）也按 0.5 缩放 ========== -->
        <!-- A) mass 不变（最省事）：保持你原 mass -->
        <geom class="kettle_collision" euler="0 1.57 0" pos="0 0 0.1295" size="0.016 0.05" type="capsule" mass=".02"/>
        <geom class="kettle_collision" pos="0.046 0 0.09"  size="0.0115 0.03" type="capsule" mass=".02"/>
        <geom class="kettle_collision" pos="-0.046 0 0.09" size="0.0115 0.03" type="capsule" mass=".02"/>
        <geom class="kettle_collision" euler="0 2.25 0" pos="-0.063 0 0.035" size="0.0155 0.025" type="cylinder" mass=".02"/>
        <geom class="kettle_collision" pos="0 0 0.029" size="0.061 0.061 0.029" type="box" mass=".8"/>

        <!-- B) 推荐：按体积缩放 mass（0.5^3 = 0.125），更符合动力学
             如果你想用这个，把上面 5 行的 mass 改成下面这些，并删除/注释上面的 A 版：
             capsule/cylinder: 0.02 * 0.125 = 0.0025
             box: 0.8 * 0.125 = 0.1
        -->
        
        <geom class="kettle_collision" euler="0 1.57 0" pos="0 0 0.1295" size="0.016 0.05" type="capsule" mass="0.0025"/>
        <geom class="kettle_collision" pos="0.046 0 0.09"  size="0.0115 0.03" type="capsule" mass="0.0025"/>
        <geom class="kettle_collision" pos="-0.046 0 0.09" size="0.0115 0.03" type="capsule" mass="0.0025"/>
        <geom class="kettle_collision" euler="0 2.25 0" pos="-0.063 0 0.035" size="0.0155 0.025" type="cylinder" mass="0.0025"/>
        <geom class="kettle_collision" pos="0 0 0.029" size="0.061 0.061 0.029" type="box" mass="0.1"/>
       

        <!-- site 同步缩放 -->
        <site type="sphere" name="kettle_site" pos="0 0 0.1295" size="0.005" group="3" rgba="1 0 0 1"/>
    </body>

</mujocoinclude>
